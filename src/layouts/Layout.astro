---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="light only">
  <meta name="supported-color-schemes" content="light only">
  <title>חברותא — למידה מונעת AI לילדי ישראל | Chavruta</title>
  <meta name="description" content="Chavruta — An open-source initiative replacing Israel's failing wartime Zoom education with AI-powered personalized learning, peer and teacher mentoring.">
  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://chavruta.org.il/">
  <meta property="og:title" content="Chavruta — AI-Powered Emergency Education for Israel's Children">
  <meta property="og:description" content="An open-source, community-driven initiative replacing Israel's failing Zoom learning with AI-powered personalized tutoring, peer mentorship, and teacher mentoring. Works on any phone, in any shelter.">
  <meta property="og:image" content="https://chavruta.org.il/assets/og-image.png">
  <meta property="og:locale" content="he_IL">
  <meta property="og:locale:alternate" content="en_US">
  <meta property="og:locale:alternate" content="ar_SA">
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Chavruta — AI-Powered Emergency Education for Israel's Children">
  <meta name="twitter:description" content="Replacing broken Zoom learning with AI tutoring on the Bagrut curriculum. In Hebrew. On any device. Works in a shelter.">
  <meta name="twitter:image" content="https://chavruta.org.il/assets/og-image.png">
  <!-- Canonical & Site Name -->
  <link rel="canonical" href="https://chavruta.org.il/">
  <meta property="og:site_name" content="Chavruta">
  <!-- Favicons -->
  <link rel="icon" href="/assets/favicon/favicon.ico" sizes="48x48">
  <link rel="icon" href="/assets/favicon/favicon.svg" type="image/svg+xml">
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon/favicon-32x32.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/favicon/apple-touch-icon.png">
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;500;600;700&family=Frank+Ruhl+Libre:wght@400;500;700&family=Heebo:wght@300;400;500;700&family=IBM+Plex+Sans+Arabic:wght@300;400;500;700&display=swap" rel="stylesheet">
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to content / דלג לתוכן</a>

  <nav class="lang-toggle" aria-label="Language selection / בחירת שפה">
    <button class="lang-btn" aria-label="Switch to English">English</button>
    <button class="lang-btn active" aria-label="עברית">עברית</button>
    <button class="lang-btn" aria-label="العربية">العربية</button>
  </nav>

  <slot />

  <script src="../scripts/lang-toggle.ts"></script>
</body>
</html>
